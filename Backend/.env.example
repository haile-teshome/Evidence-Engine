# Copy this file to .env and fill in the values you need.

# Default LLM used when the request omits "model" (anything containing
# "claude" routes to Anthropic, "gpt" to OpenAI, otherwise Ollama).
DEFAULT_MODEL=claude-sonnet-4-6

# AI provider keys (only what you intend to use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional literature-source API keys
SEMANTIC_SCHOLAR_KEY=
CORE_API_KEY=

# Required by NCBI Entrez / PubMed
ENTREZ_EMAIL=your.email@example.com

# Extra CORS origins (comma-separated). Vite dev on 5173 is allowed by default.
CORS_ORIGINS=

# Screening parallelism (defaults to 16)
PARALLEL_SCREENING_WORKERS=16
PARALLEL_AGENT_WORKERS=16
