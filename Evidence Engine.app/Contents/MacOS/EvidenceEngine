#!/bin/bash
# Self-locating: the project root is three levels up from this executable
# (Contents/MacOS -> Contents -> Evidence Engine.app -> project root).
# Keep this .app INSIDE the project folder so it stays portable when shared.
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT="$(cd "$HERE/../../.." && pwd)"
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

# Prefer the bundled Node runtime (self-contained install); fall back to a
# system Node (developer / from-source mode).
BUNDLED_NODE="$PROJECT/runtime/node/bin/node"
if [ -x "$BUNDLED_NODE" ]; then
  NODE="$BUNDLED_NODE"
elif command -v node >/dev/null 2>&1; then
  NODE="node"
else
  osascript -e 'display alert "Node.js is required" message "This copy has no bundled runtime and no system Node.js. Opening the download page — install it, then open this app again."' >/dev/null 2>&1
  open "https://nodejs.org/en/download"
  exit 1
fi

# Launch the manager DETACHED and quit immediately, so this .app never stays
# "running." If it stayed running, clicking the icon again made macOS reactivate
# it and pop a stray Google Chrome window. Now every click re-runs launch.mjs,
# which uses its single-instance lock to just focus the existing window (or start
# a fresh one if none is running).
nohup "$NODE" "$PROJECT/launch.mjs" >/dev/null 2>&1 &
exit 0
